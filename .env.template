# Databricks Configuration
# Set these in your shell environment, NOT in this .env file:
# export DATABRICKS_HOST="https://your-workspace.cloud.databricks.com"
# export DATABRICKS_TOKEN="your-databricks-token"

# Database Instance
PGINSTANCENAME=your-instance-id-here

# Database Connection
PGHOST=your-instance.database.cloud.databricks.com
PGUSER=your.email@company.com
PGPASSWORD=<auto-refreshed-by-script>
PGDATABASE=nominatim
PGPORT=5432
PGSSLMODE=require

# Nominatim Configuration
NOMINATIM_SCHEMA=public
NOMINATIM_URL=http://localhost:8000
